# https://nexty.dev/docs/start-project/enviroment

# -----------------------------------------------------------------------------
# Site info (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PRICING_PATH="/#pricing"
NEXT_PUBLIC_LOCALE_DETECTION=false
NEXT_PUBLIC_OPTIMIZED_IMAGES=false
# Login mode options: page (redirect to login), dialog (popup login dialog)
NEXT_PUBLIC_LOGIN_MODE=dialog
NEXT_PUBLIC_COOKIE_CONSENT_ENABLED="false"
NEXT_PUBLIC_USER_SOURCE_TRACKING_ENABLED="true"
NEXT_PUBLIC_RATE_LIMIT_ENABLED="false"
NEXT_PUBLIC_EMAIL_NORMALIZATION_ENABLED="false"

#------------------------------------------------------------------------
# Database
# https://nexty.dev/docs/integration/database
#------------------------------------------------------------------------
DATABASE_URL=""

#------------------------------------------------------------------------
# Auth - better-auth
# Generate BETTER_AUTH_SECRET using `openssl rand -base64 32`
# https://nexty.dev/docs/integration/auth
#------------------------------------------------------------------------
BETTER_AUTH_SECRET=""
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

#------------------------------------------------------------------------
# Cloudflare Turnstile
# https://nexty.dev/docs/integration/auth
#------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

#------------------------------------------------------------------------
# Resend
# https://nexty.dev/docs/integration/resend
# https://nexty.dev/docs/integration/domain-email
#------------------------------------------------------------------------
RESEND_API_KEY=
ADMIN_EMAIL=
ADMIN_NAME=

#------------------------------------------------------------------------
# Upstash
# https://nexty.dev/docs/integration/upstash
#------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

#------------------------------------------------------------------------
# stripe
# API Docs: https://docs.stripe.com/api
# https://nexty.dev/docs/integration/stripe
#------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_CURRENCY=usd
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Subscription Management Page
STRIPE_CUSTOMER_PORTAL_URL=/dashboard/subscription
# Stripe Radar Early Fraud Warning Response Configuration
# Controls the automatic response when Stripe Radar detects potential fraud (radar.early_fraud_warning.created event)
# Options:
#   - "refund,email": Automatically refund the fraudulent charge AND send email notification to admin
#   - "refund": Only automatically refund the fraudulent charge
#   - "email": Only send email notification to admin (no automatic refund)
# Leave empty or unset to disable automatic fraud response
STRIPE_RADAR_EARLY_FRAUD_WARNING_TYPE=refund,email


#------------------------------------------------------------------------
# creem
# API Docs: https://docs.creem.io/
#------------------------------------------------------------------------
CREEM_API_BASE_URL=https://api.creem.io/v1
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=

#------------------------------------------------------------------------
# PayPal
# API Docs: https://developer.paypal.com/docs/api/overview/
# Dashboard: https://developer.paypal.com/dashboard/
#------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_PAYPAL=false
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
# sandbox | live
NEXT_PUBLIC_PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

#------------------------------------------------------------------------
# Cloudflare R2
# https://nexty.dev/docs/integration/cloudflare-r2
#------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# R2_PUBLIC_URL should start with 'https://'
R2_PUBLIC_URL=

#------------------------------------------------------------------------
# AI
# OpenAI: https://platform.openai.com/docs/overview
# DeepSeek: https://api-docs.deepseek.com/
# Anthropic: https://docs.anthropic.com/en/docs/welcome
# Grok: https://docs.x.ai/docs/overview
# Gemini: https://ai.google.dev/gemini-api/docs
# Replicate: https://replicate.com/
# fal.ai: https://fal.ai/docs
# KIE: https://kie.ai/
# Firecrawl: https://www.firecrawl.dev/
#------------------------------------------------------------------------
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=
FIRECRAWL_API_KEY=

REPLICATE_API_TOKEN=
# Optional override for create-song lyrics. Defaults to openai/gpt-5.
REPLICATE_LYRICS_MODEL=openai/gpt-5
REPLICATE_WEBHOOK_SIGNING_SECRET=
FAL_KEY=
FAL_VERIFY_WEBHOOKS=true
KIE_API_KEY=
KIE_WEBHOOK_HMAC_KEY=
# Temporary offline create-song mock. Set KIE_SUNO_MOCK_TASK_ID=false to call
# the real KIE Suno submit API again.
KIE_SUNO_MOCK_TASK_ID=de2f8263ef5a1238d1b4570b88dcc8fb
# Recommended while mock mode is enabled: set the already-generated tracks with
# simple env vars. These take precedence over the JSON fields below and avoid
# fragile multi-line JSON parsing.
KIE_SUNO_MOCK_AUDIO_ID_A=track-a
KIE_SUNO_MOCK_TITLE_A=Version A
KIE_SUNO_MOCK_AUDIO_URL_A=
KIE_SUNO_MOCK_IMAGE_URL_A=
KIE_SUNO_MOCK_DURATION_A=
KIE_SUNO_MOCK_AUDIO_ID_B=track-b
KIE_SUNO_MOCK_TITLE_B=Version B
KIE_SUNO_MOCK_AUDIO_URL_B=
KIE_SUNO_MOCK_IMAGE_URL_B=
KIE_SUNO_MOCK_DURATION_B=
# Alternative: paste already-generated versions JSON here. If a simple audio URL
# env var is present, this JSON is ignored.
# KIE_SUNO_MOCK_VERSIONS_JSON='[{"id":"track-a","title":"Version A","audioUrl":"https://.../a.mp3","imageUrl":"https://.../a.jpg"},{"id":"track-b","title":"Version B","audioUrl":"https://.../b.mp3"}]'
KIE_SUNO_MOCK_VERSIONS_JSON=
# Alternative: paste a full KIE record-info/callback payload instead of versions.
KIE_SUNO_MOCK_RESULT_JSON=
# Base URL for video generation webhook callbacks (Replicate, fal.ai, KIE)
# Example: https://your-domain.com  or  https://xxxx.ngrok.io
WEBHOOK_BASE_URL=

# Remotion Lambda music video rendering.
# REMOTION_SERVE_URL must point to a deployed Remotion site.
# For local webhook testing, WEBHOOK_BASE_URL must be a public HTTPS tunnel
# such as ngrok or Cloudflare Tunnel because AWS Lambda must reach this app.
REMOTION_AWS_REGION=
REMOTION_FUNCTION_NAME=
REMOTION_SERVE_URL=
REMOTION_WEBHOOK_SECRET=
REMOTION_FORCE_BUCKET_NAME=

# Custom OpenAI-compatible provider (SiliconFlow, 302.ai, Together AI, etc.)
# Base URL of the OpenAI-compatible API (e.g. https://api.siliconflow.cn/v1)
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_API_KEY=
# Comma-separated models. Format: model-id:Display Name,model-id-2:Display Name 2
# Example: Qwen/Qwen2.5-72B-Instruct:Qwen2.5 72B,deepseek-ai/DeepSeek-V3:DeepSeek V3
NEXT_PUBLIC_CUSTOM_OPENAI_MODELS=

#------------------------------------------------------------------------
# Translate
# route: /api/admin/translate
# support providers: openai, deepseek, anthropic, xai, google
#------------------------------------------------------------------------
NEXT_PUBLIC_AI_MODEL_ID=
NEXT_PUBLIC_AI_PROVIDER=

# -----------------------------------------------------------------------------
# Analytics & Ads
# Docs: https://nexty.dev/docs/integration/tracking
# -----------------------------------------------------------------------------
# Google
NEXT_PUBLIC_GOOGLE_ID=
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=
# Clarity
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Plausible
NEXT_PUBLIC_PLAUSIBLE_SRC=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
PLAUSIBLE_API_KEY=
PLAUSIBLE_URL=
# Umami
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Rybbit
NEXT_PUBLIC_RYBBIT_SRC=
NEXT_PUBLIC_RYBBIT_SITE_ID=
NEXT_PUBLIC_RYBBIT_SESSION_REPLAY="true"
NEXT_PUBLIC_RYBBIT_REPLAY_MASK_SELECTORS='[".user-name", "#email"]'
# Posthog
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=

# ---
# Customer Support
# Crisp:
# ----
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# -----------------------------------------------------------------------------
# Discord
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DISCORD_INVITE_URL=""
DISCORD_WEBHOOK_URL=""

# ---
# Tolt.io(Affiliates): https://app.tolt.io/
# ---
NEXT_PUBLIC_TOLT_ID=

# -----------------------------------------------------------------------------
# Sentry (error monitoring)
# https://nexty.dev/docs/integration/pino-and-sentry
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
# Source map uploads (optional, CI only)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Set to "true" to send events in development
SENTRY_DEBUG=false

# -----------------------------------------------------------------------------
# Logging (Pino)
# -----------------------------------------------------------------------------
# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info
# If set, enables file rotation logs written to this directory
# Leave empty to log to stdout only (recommended for cloud deployments)
LOG_DIR=
