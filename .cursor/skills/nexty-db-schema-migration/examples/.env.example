# Environment Variables for Database Migration

# ===================================================
# Required Environment Variables
# ===================================================

# Old database (source) - Connection string for your existing database
OLD_DB_URL=postgresql://user:password@old-db-host.com:5432/dbname

# New database (destination) - Connection string for your new database
NEW_DB_URL=postgresql://user:password@new-db-host.com:5432/dbname

